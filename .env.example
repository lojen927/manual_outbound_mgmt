# Django 密钥（生产环境必改！使用 python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())" 生成）
DJANGO_SECRET_KEY=your-secret-key-here

# 调试模式（生产环境必须为 False）
DJANGO_DEBUG=False

# 允许访问的主机名，逗号分隔
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,121.43.235.18

# CSRF 信任来源，逗号分隔（需包含实际访问地址）
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost,http://121.43.235.18
